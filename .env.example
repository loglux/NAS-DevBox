# Copy to .env and edit for your machine:
#   cp .env.example .env

# Core user/container settings
DEVBOX_USER=dev
DEVBOX_PASS=changeme
# Leave blank to auto-use host id -u / id -g (recommended for cross-machine use)
DEVBOX_UID=
DEVBOX_GID=
DOCKER_GID=1000

# Networking / naming
DEVBOX_SSH_PORT=2202
DEVBOX_CONTAINER_NAME=devbox
DEVBOX_PLAYWRIGHT_SSH_PORT=2203
DEVBOX_PLAYWRIGHT_CONTAINER_NAME=devbox-playwright

# Host paths
DEVBOX_PROJECTS_DIR=/volume1/projects
DEVBOX_WORKSPACE_LINK=on
DEVBOX_START_DIR=/workspace
DEVBOX_PASSWORDLESS_SUDO=on
# when on, creates /workspace -> /home/<user>/projects inside container
DEVBOX_HOME_DIR=/volume1/projects/.devbox-home
